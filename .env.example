# =============================================================================
# VisionTranslate (lensmu) — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your API keys.
# These keys are entered in the extension popup settings, not loaded from
# this file directly. This file exists as documentation for contributors.
# =============================================================================

# Google Cloud Vision API key (for Google Cloud Vision OCR engine)
# Get one at: https://console.cloud.google.com/apis/credentials
GOOGLE_CLOUD_API_KEY=

# OpenAI API key (for GPT-based translation)
# Get one at: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Anthropic API key (for Claude-based translation)
# Get one at: https://console.anthropic.com/settings/keys
CLAUDE_API_KEY=

# Backend server URL (default: http://localhost:8000)
# Change this if running the backend on a different port or machine
BACKEND_URL=http://localhost:8000
